      <aliases enabled='yes' />
      <column caption='Discount Risk Level' datatype='string' name='[Calculation_1536630979416064]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [discount_pct_calc] &gt; 60 THEN &quot;🔴 Critical (&gt;60%)&quot;&#13;&#10;ELSEIF [discount_pct_calc] &gt; 40 THEN &quot;🟠 High (40–60%)&quot;&#13;&#10;ELSEIF [discount_pct_calc] &gt; 20 THEN &quot;🟡 Medium (20–40%)&quot;&#13;&#10;ELSE &quot;🟢 Low (&lt;20%)&quot;&#13;&#10;END' />
      </column>
      <column caption='OOS Revenue Loss' datatype='real' name='[Calculation_1536630979592193]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [out_of_stock] = TRUE THEN [selling_price] ELSE 0 END' />
      </column>
      <column caption='% Over-Discounted' datatype='real' name='[Calculation_1536630979702786]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [high_discount_flag] = TRUE THEN 1 ELSE 0 END) / COUNT([pid])' />
      </column>
      <column caption='Total Revenue at Risk' datatype='real' name='[Calculation_1536630980059139]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue_at_risk])' />
      </column>
      <column datatype='integer' name='[Unnamed: 0]' role='measure' type='quantitative' />
